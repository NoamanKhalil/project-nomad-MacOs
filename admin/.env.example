PORT=8080
HOST=localhost
LOG_LEVEL=info
APP_KEY=some_random_key
NODE_ENV=development
SESSION_DRIVER=cookie
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_DATABASE=nomad
DB_PASSWORD=password
DB_SSL=false
REDIS_HOST=localhost
REDIS_PORT=6379
# Storage path for NOMAD content (ZIM files, maps, etc.)
# On macOS dev, use an absolute path like: /usr/local/project-nomad/storage
# On macOS production, use: /usr/local/project-nomad/storage
NOMAD_STORAGE_PATH=/usr/local/project-nomad/storage